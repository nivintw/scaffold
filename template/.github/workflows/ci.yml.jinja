# CI — the shared lint/format/test gate. REUSABLE (on: workflow_call); the triggers
# live in the callers:
#   - pr.yml    (on: pull_request)  → this gate. The open-PR pipeline.
#   - main.yml  (on: push to main)  → this gate, THEN a release-please stage.
# Defining the gate once means both pipelines run the exact same checks.
#
# Most prek hooks self-bootstrap their pinned env. taplo + hawkeye are `language:
# system` (they expect local binaries), so prek skips them here and they run as their
# own steps below, fetching the pinned upstream release — same check, no Docker.

name: ci

on:
  workflow_call:
    inputs:
      skip-quality-gate:
        description: >-
          When true, skip the heavy lint/format/test steps but still report success.
          main.yml sets this for release-please's bump commit (already validated as the
          Release PR), so a release doesn't re-run the full gate (doubled minutes). Callers'
          `needs: ci` is unaffected because the job still succeeds.
        type: boolean
        default: false

permissions:
  contents: read

jobs:
  lint-and-test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10 # v6.0.3
        with:
          # Read-only gate — don't leave the checkout token in .git/config (zizmor artipacked).
          persist-credentials: false

      - name: Set up uv (+ managed Python)
        uses: astral-sh/setup-uv@d0cc045d04ccac9d8b7881df0226f9e82c39688e # v6.8.0
        with:
          enable-cache: true

      - name: Cache prek hook environments
        uses: actions/cache@27d5ce7f107fe9357f9df03efb73ab90386fccae # v5.0.5
        with:
          path: ~/.cache/prek
          key: prek-${{ '{{' }} hashFiles('.pre-commit-config.yaml') {{ '}}' }}
{% if include_terraform %}
      - name: Install trivy (terraform IaC scan — runs inside the prek gate)
        if: inputs.skip-quality-gate != true
        env:
          # renovate: datasource=github-releases depName=aquasecurity/trivy
          TRIVY_VERSION: "0.71.2"
        run: |
          curl -fsSL "https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VERSION}/trivy_${TRIVY_VERSION}_Linux-64bit.tar.gz" \
            | tar -xz -C "$RUNNER_TEMP" trivy
          echo "$RUNNER_TEMP" >>"$GITHUB_PATH"
{% endif %}{% if has_python %}
      - name: Install osv-scanner (dependency CVE scan — runs inside the prek gate)
        if: inputs.skip-quality-gate != true
        env:
          # renovate: datasource=github-releases depName=google/osv-scanner
          OSV_VERSION: "2.4.0"
        run: |
          curl -fsSL "https://github.com/google/osv-scanner/releases/download/v${OSV_VERSION}/osv-scanner_linux_amd64" \
            -o "$RUNNER_TEMP/osv-scanner"
          chmod +x "$RUNNER_TEMP/osv-scanner"
          echo "$RUNNER_TEMP" >>"$GITHUB_PATH"
{% endif %}
      - name: Run prek hooks (same as local)
        if: inputs.skip-quality-gate != true
        env:
          # taplo/hawkeye run as dedicated steps below; no-commit-to-branch is a
          # commit-time guard meaningless in CI (we're checked out on the branch). zizmor
          # runs --offline in the hook (token-free local gate) and is SKIP'd here so CI
          # runs the FULL online audit as the dedicated step below instead.
          SKIP: taplo,hawkeye-format,no-commit-to-branch,zizmor
        run: uvx prek run --all-files

      - name: Audit workflows for security issues (zizmor, online)
        if: inputs.skip-quality-gate != true
        # The prek zizmor hook is --offline (deterministic, token-free) and SKIP'd above, so
        # CI runs the full audit here — the network audits (known-vulnerable-actions,
        # ref-confusion) need a GH token; the AST audits run as in the hook. Pinned to the
        # hook's zizmor version; contents:read suffices to query the advisory DB + resolve refs.
        env:
          GH_TOKEN: ${{ '{{' }} github.token {{ '}}' }}
          # renovate: datasource=pypi depName=zizmor
          ZIZMOR_VERSION: "1.26.1"
        run: uvx "zizmor@${ZIZMOR_VERSION}" --no-progress .github/workflows/

      - name: Check SPDX license headers (hawkeye)
        if: inputs.skip-quality-gate != true
        # renovate: datasource=github-releases depName=korandoru/hawkeye
        run: |
          curl -fsSL https://github.com/korandoru/hawkeye/releases/download/v6.5.1/hawkeye-x86_64-unknown-linux-gnu.tar.xz \
            | tar -xJ --strip-components=1 -C "$RUNNER_TEMP" hawkeye-x86_64-unknown-linux-gnu/hawkeye
          chmod +x "$RUNNER_TEMP/hawkeye"
          "$RUNNER_TEMP/hawkeye" check --config .config/licenserc.toml

      - name: Check TOML formatting (taplo)
        if: inputs.skip-quality-gate != true
        # renovate: datasource=github-releases depName=tamasfe/taplo
        run: |
          curl -fsSL https://github.com/tamasfe/taplo/releases/download/0.10.0/taplo-linux-x86_64.gz \
            | gunzip -c >"$RUNNER_TEMP/taplo"
          chmod +x "$RUNNER_TEMP/taplo"
          "$RUNNER_TEMP/taplo" fmt --check --diff
{% if 'pytest' in test_frameworks %}
      - name: Tests (pytest)
        if: inputs.skip-quality-gate != true
        run: uv run pytest
{% endif %}{% if 'bats' in test_frameworks %}
      - name: Shell tests (bats)
        if: inputs.skip-quality-gate != true
        run: |
          sudo apt-get update -qq
          sudo apt-get install -y -qq bats
          bats tests/
{% endif %}{% if include_terraform %}
      - name: Terraform fmt + validate
        if: inputs.skip-quality-gate != true
        uses: hashicorp/setup-terraform@b9cd54a3c349d3f38e8881555d616ced269862dd # v3.1.2
      - name: terraform fmt -check
        if: inputs.skip-quality-gate != true
        run: terraform -chdir=terraform fmt -check -recursive
{% endif %}{% if include_helm %}
      - name: Helm lint
        if: inputs.skip-quality-gate != true
        uses: azure/setup-helm@1a275c3b69536ee54be43f2070a358922e12c8d4 # v4.3.1
      - if: inputs.skip-quality-gate != true
        run: helm lint helm/{{ project_slug }}
{% endif %}