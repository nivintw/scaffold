# CI — the shared lint/format/test gate. REUSABLE (on: workflow_call); the triggers
# live in the callers:
#   - pr.yml    (on: pull_request)  → this gate. The open-PR pipeline.
#   - main.yml  (on: push to main)  → this gate, THEN a release-please stage.
# Defining the gate once means both pipelines run the exact same checks.
#
# Most prek hooks self-bootstrap their pinned env. taplo + hawkeye are `language:
# system` (they expect local binaries), so prek skips them here and they run as their
# own steps below, fetching the pinned upstream release — same check, no Docker.

name: ci

on:
  workflow_call:
    inputs:
      skip-quality-gate:
        description: >-
          When true, skip the heavy lint/format/test steps but still report success.
          main.yml sets this for release-please's bump commit (already validated as the
          Release PR), so a release doesn't re-run the full gate (doubled minutes). Callers'
          `needs: ci` is unaffected because the job still succeeds.
        type: boolean
        default: false

permissions:
  contents: read

jobs:
  lint-and-test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10 # v6.0.3
        with:
          # Read-only gate — don't leave the checkout token in .git/config (zizmor artipacked).
          persist-credentials: false

      - name: Set up uv (+ managed Python)
        uses: astral-sh/setup-uv@d0cc045d04ccac9d8b7881df0226f9e82c39688e # v6.8.0
        with:
          enable-cache: true

      - name: Cache prek hook environments
        uses: actions/cache@27d5ce7f107fe9357f9df03efb73ab90386fccae # v5.0.5
        with:
          path: ~/.cache/prek
          key: prek-${{ '{{' }} hashFiles('.pre-commit-config.yaml') {{ '}}' }}
          # Fall back to any prior prek cache so a hook-rev bump rebuilds only the changed
          # env (not all of them) — matters more now there are more, oftener-bumped hooks.
          restore-keys: |
            prek-
{% if include_terraform or include_docker %}
      - name: Install trivy (Dockerfile/IaC scan — runs inside the prek gate)
        if: inputs.skip-quality-gate != true
        env:
          # renovate: datasource=github-releases depName=aquasecurity/trivy
          TRIVY_VERSION: "0.71.2"
          # SHA256 of trivy_${TRIVY_VERSION}_Linux-64bit.tar.gz — refreshed with the version
          # by scripts/refresh-binary-checksums.sh (run as a Renovate postUpgradeTask).
          TRIVY_SHA256: "0510e71e2fd39bf863856d499c8dc19feb4e7336546394c502a8f5cc7ab27460"  # gitleaks:allow
        run: |
          set -euo pipefail
          curl -fsSL --retry 5 --retry-all-errors --retry-delay 2 --retry-max-time 60 \
            "https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VERSION}/trivy_${TRIVY_VERSION}_Linux-64bit.tar.gz" \
            -o "$RUNNER_TEMP/trivy.tar.gz"
          echo "${TRIVY_SHA256}  $RUNNER_TEMP/trivy.tar.gz" | sha256sum -c -
          tar -xz -C "$RUNNER_TEMP" -f "$RUNNER_TEMP/trivy.tar.gz" trivy
          echo "$RUNNER_TEMP" >>"$GITHUB_PATH"
{% endif %}{% if has_python %}
      - name: Install osv-scanner (dependency CVE scan — runs inside the prek gate)
        if: inputs.skip-quality-gate != true
        env:
          # renovate: datasource=github-releases depName=google/osv-scanner
          OSV_VERSION: "2.4.0"
          # SHA256 of osv-scanner_linux_amd64 (the published asset is the bare binary) —
          # refreshed with the version by scripts/refresh-binary-checksums.sh.
          OSV_SHA256: "15314940c10d26af9c6649f150b8a47c1262e8fc7e17b1d1029b0e479e8ed8a0"  # gitleaks:allow
        run: |
          set -euo pipefail
          curl -fsSL --retry 5 --retry-all-errors --retry-delay 2 --retry-max-time 60 \
            "https://github.com/google/osv-scanner/releases/download/v${OSV_VERSION}/osv-scanner_linux_amd64" \
            -o "$RUNNER_TEMP/osv-scanner"
          echo "${OSV_SHA256}  $RUNNER_TEMP/osv-scanner" | sha256sum -c -
          chmod +x "$RUNNER_TEMP/osv-scanner"
          echo "$RUNNER_TEMP" >>"$GITHUB_PATH"
{% endif %}{% if include_terraform %}
      - name: Set up Terraform (backs the terraform_fmt/validate prek hooks)
        if: inputs.skip-quality-gate != true
        uses: hashicorp/setup-terraform@b9cd54a3c349d3f38e8881555d616ced269862dd # v3.1.2
        with:
          # The default wrapper rewrites `terraform` to emit extra output, which breaks the
          # terraform_validate hook's JSON parsing. Disable it so the hook sees raw output.
          terraform_wrapper: false
      - name: Set up tflint (backs the terraform_tflint prek hook)
        if: inputs.skip-quality-gate != true
        uses: terraform-linters/setup-tflint@b480b8fcdaa6f2c577f8e4fa799e89e756bb7c93 # v6.2.2
{% endif %}{% if include_helm %}
      - name: Set up Helm (backs the helm-lint prek hook + the kubeconform step below)
        if: inputs.skip-quality-gate != true
        uses: azure/setup-helm@1a275c3b69536ee54be43f2070a358922e12c8d4 # v4.3.1
{% endif %}
      - name: Run prek hooks (same as local)
        if: inputs.skip-quality-gate != true
        env:
          # taplo/hawkeye run as dedicated steps below; no-commit-to-branch is a
          # commit-time guard meaningless in CI (we're checked out on the branch). zizmor
          # runs --offline in the hook (token-free local gate) and is SKIP'd here so CI
          # runs the FULL online audit as the dedicated step below instead.
          SKIP: taplo,hawkeye-format,no-commit-to-branch,zizmor
        run: uvx prek run --all-files

      - name: Audit workflows for security issues (zizmor, online)
        if: inputs.skip-quality-gate != true
        # The prek zizmor hook is --offline (deterministic, token-free) and SKIP'd above, so
        # CI runs the full audit here — the network audits (known-vulnerable-actions,
        # ref-confusion) need a GH token; the AST audits run as in the hook. Pinned to the
        # hook's zizmor version; contents:read suffices to query the advisory DB + resolve refs.
        env:
          GH_TOKEN: ${{ '{{' }} github.token {{ '}}' }}
          # renovate: datasource=pypi depName=zizmor
          ZIZMOR_VERSION: "1.26.1"
        run: uvx "zizmor@${ZIZMOR_VERSION}" --no-progress .github/workflows/

      - name: Check SPDX license headers (hawkeye)
        if: inputs.skip-quality-gate != true
        env:
          # renovate: datasource=github-releases depName=korandoru/hawkeye
          HAWKEYE_VERSION: "6.5.1"
          # SHA256 of hawkeye-x86_64-unknown-linux-gnu.tar.xz — refreshed with the version
          # by scripts/refresh-binary-checksums.sh.
          HAWKEYE_SHA256: "d6eb0505a45a15244f4f789158aafe5e3f1a7dc86c9dc1d7651f3cb1e1b321e0"  # gitleaks:allow
        run: |
          set -euo pipefail
          curl -fsSL --retry 5 --retry-all-errors --retry-delay 2 --retry-max-time 60 \
            "https://github.com/korandoru/hawkeye/releases/download/v${HAWKEYE_VERSION}/hawkeye-x86_64-unknown-linux-gnu.tar.xz" \
            -o "$RUNNER_TEMP/hawkeye.tar.xz"
          echo "${HAWKEYE_SHA256}  $RUNNER_TEMP/hawkeye.tar.xz" | sha256sum -c -
          tar -xJ --strip-components=1 -C "$RUNNER_TEMP" -f "$RUNNER_TEMP/hawkeye.tar.xz" hawkeye-x86_64-unknown-linux-gnu/hawkeye
          chmod +x "$RUNNER_TEMP/hawkeye"
          "$RUNNER_TEMP/hawkeye" check --config .config/licenserc.toml

      - name: Check TOML formatting (taplo)
        if: inputs.skip-quality-gate != true
        env:
          # renovate: datasource=github-releases depName=tamasfe/taplo
          TAPLO_VERSION: "0.10.0"
          # SHA256 of taplo-linux-x86_64.gz. taplo ships no upstream checksum file, so this is
          # computed from the asset by scripts/refresh-binary-checksums.sh.
          TAPLO_SHA256: "8fe196b894ccf9072f98d4e1013a180306e17d244830b03986ee5e8eabeb6156"  # gitleaks:allow
        run: |
          set -euo pipefail
          curl -fsSL --retry 5 --retry-all-errors --retry-delay 2 --retry-max-time 60 \
            "https://github.com/tamasfe/taplo/releases/download/${TAPLO_VERSION}/taplo-linux-x86_64.gz" \
            -o "$RUNNER_TEMP/taplo.gz"
          echo "${TAPLO_SHA256}  $RUNNER_TEMP/taplo.gz" | sha256sum -c -
          gunzip -c "$RUNNER_TEMP/taplo.gz" >"$RUNNER_TEMP/taplo"
          chmod +x "$RUNNER_TEMP/taplo"
          "$RUNNER_TEMP/taplo" fmt --check --diff
{% if 'pytest' in test_frameworks %}
      - name: Tests (pytest)
        if: inputs.skip-quality-gate != true
        run: uv run pytest
{% endif %}{% if 'bats' in test_frameworks %}
      - name: Shell tests (bats)
        if: inputs.skip-quality-gate != true
        run: |
          sudo apt-get update -qq
          sudo apt-get install -y -qq bats
          bats tests/
{% endif %}{% if include_docker %}
      - name: Build image + scan for CVEs (trivy image)
        if: inputs.skip-quality-gate != true
        # Image-layer CVE scan — needs a *built* image, so it runs here, not in the prek gate
        # (which only scans the Dockerfile via `trivy config`). --ignore-unfixed skips
        # base-image CVEs with no available fix (keeps the gate actionable); HIGH/CRITICAL
        # only. trivy is already on PATH (installed above).
        run: |
          docker build -t {{ project_slug }}:ci .
          trivy image --exit-code 1 --ignore-unfixed --severity HIGH,CRITICAL {{ project_slug }}:ci
{% endif %}{% if include_helm %}
      - name: Validate rendered manifests (kubeconform)
        if: inputs.skip-quality-gate != true
        # `helm lint` runs in the prek gate; kubeconform validates the rendered manifests
        # against upstream Kubernetes schemas (a network fetch), so it runs here.
        # -ignore-missing-schemas: a CRD/Custom Resource the chart adds has no upstream schema;
        # skip those rather than fail (a valid manifest shouldn't redden CI). -strict still
        # rejects unknown fields on the built-in kinds it does know.
        env:
          # renovate: datasource=github-releases depName=yannh/kubeconform
          KUBECONFORM_VERSION: "0.8.0"
          # SHA256 of kubeconform-linux-amd64.tar.gz — refreshed with the version by
          # scripts/refresh-binary-checksums.sh.
          KUBECONFORM_SHA256: "9bc2bffbf71f261128533edaf912153948b7ff238f9a531ae6d34466ec287883"  # gitleaks:allow
        run: |
          set -euo pipefail
          curl -fsSL --retry 5 --retry-all-errors --retry-delay 2 --retry-max-time 60 \
            "https://github.com/yannh/kubeconform/releases/download/v${KUBECONFORM_VERSION}/kubeconform-linux-amd64.tar.gz" \
            -o "$RUNNER_TEMP/kubeconform.tar.gz"
          echo "${KUBECONFORM_SHA256}  $RUNNER_TEMP/kubeconform.tar.gz" | sha256sum -c -
          tar -xz -C "$RUNNER_TEMP" -f "$RUNNER_TEMP/kubeconform.tar.gz" kubeconform
          helm template helm/{{ project_slug }} | "$RUNNER_TEMP/kubeconform" -strict -ignore-missing-schemas -summary
{% endif %}