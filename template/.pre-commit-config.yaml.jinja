# SPDX-FileCopyrightText: © {{ year }} {{ author_name }}
# SPDX-License-Identifier: {{ license }}

# Pre-commit hooks, run by prek (https://github.com/j178/prek). Designed to run
# identically in CI — most hooks self-bootstrap a pinned env.
#   Run on demand:  uvx prek run --all-files
#   Install hooks:  uvx prek install

default_install_hook_types: [pre-commit, commit-msg]
default_stages: [pre-commit, manual]

repos:
  # ------------------------------ 🔧 Meta / Self-checks ----------------------------- #
  - repo: meta
    hooks:
      # NOTE: check-hooks-apply is intentionally omitted. A freshly-scaffolded repo can
      # legitimately have hygiene hooks (check-json, etc.) that match zero files until
      # the project grows, and that meta-hook would fail the gate on those.
      - id: check-useless-excludes
        name: "🔧 pre-commit · Check for useless excludes"

  # ------------------------------- 🌳 Git Hygiene ----------------------------------- #
  - repo: builtin
    hooks:
      - id: check-added-large-files
        name: "🌳 git · Block large file commits"
        args: ["--maxkb=1024"]
      - id: check-merge-conflict
        name: "🌳 git · Detect conflict markers"
      - id: no-commit-to-branch
        name: "🌳 git · Protect main (commit via a branch, then merge)"
      - id: check-case-conflict
        name: "🌳 git · Detect case-insensitive name clashes"
      - id: check-shebang-scripts-are-executable
        name: "🌳 git · Shebang scripts must be executable"
      - id: check-executables-have-shebangs
        name: "🌳 git · Executables must have a shebang"
      - id: detect-private-key
        name: "🔒 security · Block committed private keys"
      - id: mixed-line-ending
        name: "🧹 cleanup · Normalize line endings (LF)"
        args: ["--fix=lf"]
      - id: trailing-whitespace
        name: "🧹 cleanup · Remove trailing whitespace"
        args: ["--markdown-linebreak-ext=md"]
      - id: end-of-file-fixer
        name: "🧹 cleanup · Ensure single newline at EOF"
      - id: check-yaml
        name: "🗂️ config · Validate YAML"
{%- if include_helm %}
        # Helm templates are Go-templated, not valid YAML — `helm lint` validates them.
        exclude: '^helm/[^/]+/templates/'
{%- endif %}
      - id: check-json
        name: "🗂️ config · Validate JSON"
        files: '\.json$'
        # VS Code's .vscode/*.json are JSONC (comments + trailing commas) — valid for VS Code
        # but not strict JSON, so check-json can't parse them. Match .vscode/ at any depth.
        exclude: '(^|/)\.vscode/'
      - id: check-toml
        name: "🗂️ config · Validate TOML"

  # -------------------------------- 🐚 Shell ---------------------------------------- #
  - repo: https://github.com/shellcheck-py/shellcheck-py
    rev: v0.11.0.1
    hooks:
      - id: shellcheck
        name: "🐚 shell · Lint shell scripts with shellcheck"
        args: ["-s", "bash", "-x"]

  - repo: https://github.com/maxwinterstein/shfmt-py
    rev: v4.0.0
    hooks:
      - id: shfmt
        name: "🐚 shell · Format shell scripts with shfmt"
        # -i 2 matches .editorconfig (indent_size = 2).
        args: ["-w", "-i", "2"]
{%- if 'bats' in test_frameworks %}
        # bats files are identified as shell but use `@test` syntax shfmt can't parse;
        # exclude them (shellcheck still lints them via its own hook). Only emitted for the
        # bats shape — otherwise check-useless-excludes flags an exclude matching no files.
        exclude: '\.bats$'
{%- endif %}

  # ----------------------------- ⚙️ GitHub Actions ---------------------------------- #
  # actionlint lints the workflows (and shellchecks their `run:` blocks); zizmor security-
  # audits them. Both are pip-backed hooks that self-bootstrap a pinned env — no system
  # binary, so they run identically locally and in CI.
  - repo: https://github.com/Mateusz-Grzelinski/actionlint-py
    rev: v1.7.12.24
    hooks:
      - id: actionlint
        name: "⚙️ ci · Lint workflows with actionlint"
        # shellcheck-py puts a shellcheck on PATH so actionlint can lint `run:` blocks
        # without depending on a system install.
        additional_dependencies: ["shellcheck-py"]

  - repo: https://github.com/woodruffw/zizmor-pre-commit
    rev: v1.26.1
    hooks:
      - id: zizmor
        name: "🔒 ci · Audit workflows for security issues (zizmor)"
        # --offline keeps THIS hook deterministic and token-free: the AST audits (template
        # injection, excessive permissions, artipacked, …) run offline everywhere. The
        # network audits (known-vulnerable-actions, ref-confusion) need a GH token, so they
        # don't run in this hook — CI runs the FULL zizmor audit (online) as a dedicated
        # step that SKIPs this hook (see ci.yml). Overriding args drops the upstream
        # default, so re-add --no-progress.
        args: ["--no-progress", "--offline"]

  # ------------------------------- 🔒 Security -------------------------------------- #
  - repo: https://github.com/gitleaks/gitleaks
    rev: v8.30.1
    hooks:
      - id: gitleaks
        name: "🔒 security · Detect secrets with gitleaks"
{% if has_python %}
  # ----------------------- 🔒 Dependency CVEs (supply chain) ------------------------ #
  # ruff `ALL` lints the *code*, not the dependency tree. `uv audit` checks the resolved
  # deps against PyPA advisories; osv-scanner cross-checks uv.lock against the OSV database
  # (and also handles non-Python lockfiles). Both are system tools — uv ships `audit`, and
  # osv-scanner is a release binary, like hawkeye/taplo — so CI and local match (see the
  # SYSTEM TOOLS note under Licensing for where these binaries come from).
  - repo: local
    hooks:
      - id: uv-audit
        name: "🔒 deps · Audit dependencies for CVEs (uv audit)"
        entry: uv audit --preview-features audit-command
        language: system
        files: '^(pyproject\.toml|uv\.lock)$'
        pass_filenames: false
      - id: osv-scanner
        name: "🔒 deps · Scan uv.lock for CVEs (osv-scanner)"
        entry: osv-scanner scan source --lockfile uv.lock
        language: system
        files: '^uv\.lock$'
        pass_filenames: false
{% endif %}
  # --------------------------- ⚖️ Licensing & Compliance ---------------------------- #
  # hawkeye maintains the SPDX headers (config: .config/licenserc.toml); reuse verifies overall
  # REUSE compliance. hawkeye is a system release binary (like taplo/osv-scanner/trivy).
  # SYSTEM TOOLS: this template emits NO Brewfile — CI installs these binaries per run, but
  # install them locally too so `prek run --all-files` matches CI (the README "Quality gate"
  # section lists them). The canonical nivintw setup provides them via the Brewfile in the
  # https://github.com/nivintw/dotfiles repo; a generic adopter supplies their own equivalent.
  - repo: local
    hooks:
      - id: hawkeye-format
        name: "⚖️ license · Add/format SPDX headers with hawkeye"
        entry: hawkeye format --config .config/licenserc.toml
        language: system
        pass_filenames: false
        require_serial: true

  - repo: https://github.com/fsfe/reuse-tool
    rev: v6.2.0
    hooks:
      - id: reuse
        name: "⚖️ license · Check REUSE compliance"

  # ------------------------------- ✨ Spelling -------------------------------------- #
  - repo: https://github.com/crate-ci/typos
    rev: v1.47.2
    hooks:
      - id: typos
        name: "✨ language · Check spelling with typos"
        # CHECK-ONLY: drop the hook default --write-changes; keep --force-exclude.
        # Scan `.` plus `.config` explicitly: typos skips hidden dirs by default, so the
        # configs relocated under .config/ go unchecked unless named (an explicit path
        # overrides the hidden-skip). .git/.venv stay unscanned — they aren't listed.
        args: ["--force-exclude", "--config", ".config/typos.toml", ".", ".config"]
        pass_filenames: false
{% if include_docker %}
  # -------------------------------- 🐳 Docker --------------------------------------- #
  # hadolint is the Dockerfile analog of shellcheck. hadolint-py is pip-backed so it
  # self-bootstraps (no Docker/system install needed).
  - repo: https://github.com/AleksaC/hadolint-py
    rev: v2.14.0
    hooks:
      - id: hadolint
        name: "🐳 docker · Lint Dockerfile with hadolint"

  # trivy config applies misconfiguration policies hadolint doesn't (missing HEALTHCHECK,
  # running as root, …). Image-layer CVE scanning needs a *built* image, so `trivy image`
  # runs in CI (build-then-scan) — see .github/workflows. trivy is a system release binary,
  # like hawkeye/taplo (see the SYSTEM TOOLS note under Licensing).
  - repo: local
    hooks:
      - id: trivy-dockerfile
        name: "🐳 docker · Scan Dockerfile for misconfig (trivy config)"
        # --exit-code 1 makes findings fail the gate (trivy exits 0 by default). HIGH/CRITICAL
        # only (matching the trivy image scan): LOW/MEDIUM advisories like "add a HEALTHCHECK"
        # are app-specific and can't be templated meaningfully — drop --severity to surface them.
        # --skip-check-update uses trivy's bundled checks instead of fetching the policy bundle,
        # so this gate hook stays offline/deterministic (the online image scan lives in CI).
        entry: trivy config --exit-code 1 --skip-check-update --severity HIGH,CRITICAL Dockerfile
        language: system
        pass_filenames: false
        files: '^Dockerfile$'
{% endif %}{% if include_terraform %}
  # ------------------------------- 🏗️ Terraform ------------------------------------- #
  # Two layers. antonbabenko/pre-commit-terraform wraps the local `terraform`/`tflint`
  # binaries for fmt/validate/lint (syntax + style); then checkov/trivy scan for *security*
  # misconfig (e.g. a public bucket) that fmt/validate miss. terraform_validate self-runs
  # `terraform init -backend=false` — offline only while no providers are declared (the stub
  # declares none); add a provider and `validate` becomes a network op (provider download),
  # like any terraform repo. tflint's bundled rules run offline (`tflint --init` is only
  # needed once you configure cloud plugins). checkov is pip-backed (self-bootstraps); trivy
  # is a system release binary (see the SYSTEM TOOLS note under Licensing).
  - repo: https://github.com/antonbabenko/pre-commit-terraform
    rev: v1.108.0
    hooks:
      - id: terraform_fmt
        name: "🏗️ terraform · Format (terraform fmt)"
      - id: terraform_validate
        name: "🏗️ terraform · Validate (terraform validate)"
      - id: terraform_tflint
        name: "🏗️ terraform · Lint (tflint)"

  - repo: https://github.com/bridgecrewio/checkov
    rev: 3.3.1
    hooks:
      - id: checkov
        name: "🏗️ terraform · Scan IaC for misconfig (checkov)"
        # Terraform only — zizmor audits workflows, hadolint the Dockerfile.
        args: ["--framework", "terraform", "--quiet", "--compact"]

  - repo: local
    hooks:
      - id: trivy
        name: "🏗️ terraform · Scan IaC for misconfig (trivy)"
        # --exit-code 1 makes findings fail the gate (trivy exits 0 by default). No --severity
        # filter here (unlike the Dockerfile hook): IaC misconfigs are the user's own resources
        # (e.g. a public bucket) where blocking even MEDIUM is worthwhile, whereas the Dockerfile
        # carries un-templatable LOW/MEDIUM noise (HEALTHCHECK) that HIGH/CRITICAL scoping drops.
        # --skip-check-update uses trivy's bundled checks (no policy-bundle fetch) so the gate
        # stays offline/deterministic.
        entry: trivy config --exit-code 1 --skip-check-update terraform
        language: system
        pass_filenames: false
        files: '\.tf$'
{% endif %}{% if include_helm %}
  # --------------------------------- ⎈ Helm ---------------------------------------- #
  # `helm lint` runs the local helm binary (offline). Schema validation (kubeconform) needs
  # to fetch upstream Kubernetes schemas, so it runs in CI — see .github/workflows.
  - repo: local
    hooks:
      - id: helm-lint
        name: "⎈ helm · Lint chart (helm lint)"
        entry: helm lint helm/{{ project_slug }}
        language: system
        pass_filenames: false
        files: '^helm/'
{% endif %}{% if include_sql %}
  # ---------------------------------- 🗄️ SQL ---------------------------------------- #
  # sqlfluff lints AND fixes across dialects (config: .sqlfluff). pip-backed → self-
  # bootstraps. fix first (autofix), then lint catches what can't be auto-fixed — the
  # ruff check+format pattern, for SQL.
  - repo: https://github.com/sqlfluff/sqlfluff
    rev: 4.2.2
    hooks:
      - id: sqlfluff-fix
        name: "🗄️ sql · Fix SQL with sqlfluff"
{%- if sql_use_dbt %}
        # The dbt templater is a separate package, and the hook runs in an isolated venv, so
        # it must be installed here. You still need a reachable dbt project to lint models.
        additional_dependencies: ["sqlfluff-templater-dbt"]
{%- endif %}
      - id: sqlfluff-lint
        name: "🗄️ sql · Lint SQL with sqlfluff"
{%- if sql_use_dbt %}
        additional_dependencies: ["sqlfluff-templater-dbt"]
{%- endif %}
{% endif %}{% if has_ansible %}
  # -------------------------------- 🅰️ Ansible -------------------------------------- #
  # ansible-lint's official hook: a self-bootstrapping pinned env whose rev Renovate's
  # pre-commit manager bumps (like ruff/yamllint). It runs ansible's own `--syntax-check`
  # internally, so no separate syntax-check hook is needed. Collections resolve from Ansible's
  # default path; install the project's requirements.yml there (CI does this before the gate)
  # via `ansible-galaxy install -r requirements.yml`. The hook is fully self-contained (no
  # pyproject/venv), which is what keeps an Ansible-only repo Python-free.
  - repo: https://github.com/ansible/ansible-lint
    rev: v26.4.0
    hooks:
      - id: ansible-lint
        name: "🅰️ ansible · Lint playbooks/roles with ansible-lint"
{% endif %}{% if has_python %}
  # -------------------------------- 🐍 Python --------------------------------------- #
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.15.20
    hooks:
      - id: ruff-check
        name: "🐍 python · Lint with Ruff"
        args: [--fix, --exit-non-zero-on-fix]
      - id: ruff-format
        name: "🐍 python · Format with Ruff"

  - repo: https://github.com/abravalheri/validate-pyproject
    rev: v0.25
    hooks:
      - id: validate-pyproject
        name: "🐍 python · Validate pyproject.toml"
        additional_dependencies: ["validate-pyproject-schema-store[all]"]
{% endif %}
  # --------------------------------- 📐 YAML ---------------------------------------- #
  # check-yaml (above) only checks that YAML *parses*; yamllint enforces style — indentation,
  # key duplicates, truthy values, … (config: .config/yamllint.yaml). pip-backed → self-bootstraps.
  - repo: https://github.com/adrienverge/yamllint
    rev: v1.38.0
    hooks:
      - id: yamllint
        name: "📐 yaml · Lint YAML style with yamllint"
        args: ["-c", ".config/yamllint.yaml"]
{%- if include_helm %}
        # Helm templates are Go-templated, not valid YAML (same exclude as check-yaml).
        exclude: '^helm/[^/]+/templates/'
{%- endif %}

  # -------------------------------- 📝 Markdown ------------------------------------- #
  - repo: https://github.com/rvben/rumdl-pre-commit
    rev: v0.2.17
    hooks:
      - id: rumdl
        name: "📝 markdown · Lint/format with rumdl"
        args: [--fix, --config, .config/rumdl.toml]
{% if has_python %}
  # ----------------------------- ⚙️ Environment ------------------------------------- #
  - repo: https://github.com/astral-sh/uv-pre-commit
    rev: 0.11.26
    hooks:
      - id: uv-lock
        name: "⚙️ uv · Keep uv.lock in sync with pyproject.toml"
{% endif %}
  # ------------------------------ ✨ Commit Messages -------------------------------- #
  # Plain Conventional Commits (no gitmoji): release-please derives version bumps from
  # commit types and cannot parse a leading emoji, so commits must start with the bare type.
  - repo: https://github.com/commitizen-tools/commitizen
    rev: v4.16.3
    hooks:
      - id: commitizen
        name: "✨ commit-msg · Enforce Conventional Commits"
        stages: [commit-msg]

  # --------------------- 🛠️ Local Tools (prek can't bootstrap) ---------------------- #
  - repo: local
    hooks:
      - id: prek-validate-config
        name: "🔧 pre-commit · Validate .pre-commit-config.yaml"
        entry: prek validate-config
        language: system
        files: '^\.pre-commit-config\.yaml$'
{% if has_python %}
      - id: ty
        name: "🐍 python · Type-check with ty"
        entry: uv run ty check .
        language: system
        types: [python]
        pass_filenames: false
{% endif %}
      - id: taplo
        name: "📝 toml · Format with taplo"
        entry: taplo format
        language: system
        types: [toml]
        pass_filenames: false
