# SPDX-FileCopyrightText: © {{ year }} {{ author_name }}
# SPDX-License-Identifier: {{ license }}

# Pre-commit hooks, run by prek (https://github.com/j178/prek). Designed to run
# identically in CI — most hooks self-bootstrap a pinned env.
#   Run on demand:  uvx prek run --all-files
#   Install hooks:  uvx prek install

default_install_hook_types: [pre-commit, commit-msg]
default_stages: [pre-commit, manual]

repos:
  # ------------------------------ 🔧 Meta / Self-checks ----------------------------- #
  - repo: meta
    hooks:
      # NOTE: check-hooks-apply is intentionally omitted. A freshly-scaffolded repo can
      # legitimately have hygiene hooks (check-json, etc.) that match zero files until
      # the project grows, and that meta-hook would fail the gate on those.
      - id: check-useless-excludes
        name: "🔧 pre-commit · Check for useless excludes"

  # ------------------------------- 🌳 Git Hygiene ----------------------------------- #
  - repo: builtin
    hooks:
      - id: check-added-large-files
        name: "🌳 git · Block large file commits"
        args: ["--maxkb=1024"]
      - id: check-merge-conflict
        name: "🌳 git · Detect conflict markers"
      - id: no-commit-to-branch
        name: "🌳 git · Protect main (commit via a branch, then merge)"
      - id: check-case-conflict
        name: "🌳 git · Detect case-insensitive name clashes"
      - id: check-shebang-scripts-are-executable
        name: "🌳 git · Shebang scripts must be executable"
      - id: check-executables-have-shebangs
        name: "🌳 git · Executables must have a shebang"
      - id: detect-private-key
        name: "🔒 security · Block committed private keys"
      - id: mixed-line-ending
        name: "🧹 cleanup · Normalize line endings (LF)"
        args: ["--fix=lf"]
      - id: trailing-whitespace
        name: "🧹 cleanup · Remove trailing whitespace"
        args: ["--markdown-linebreak-ext=md"]
      - id: end-of-file-fixer
        name: "🧹 cleanup · Ensure single newline at EOF"
      - id: check-yaml
        name: "🗂️ config · Validate YAML"
{%- if include_helm %}
        # Helm templates are Go-templated, not valid YAML — `helm lint` validates them.
        exclude: '^helm/[^/]+/templates/'
{%- endif %}
      - id: check-json
        name: "🗂️ config · Validate JSON"
        files: '\.json$'
      - id: check-toml
        name: "🗂️ config · Validate TOML"

  # -------------------------------- 🐚 Shell ---------------------------------------- #
  - repo: https://github.com/shellcheck-py/shellcheck-py
    rev: v0.11.0.1
    hooks:
      - id: shellcheck
        name: "🐚 shell · Lint shell scripts with shellcheck"
        args: ["-s", "bash", "-x"]

  - repo: https://github.com/maxwinterstein/shfmt-py
    rev: v4.0.0
    hooks:
      - id: shfmt
        name: "🐚 shell · Format shell scripts with shfmt"
        # -i 2 matches .editorconfig (indent_size = 2).
        args: ["-w", "-i", "2"]
{%- if 'bats' in test_frameworks %}
        # bats files are identified as shell but use `@test` syntax shfmt can't parse;
        # exclude them (shellcheck still lints them via its own hook). Only emitted for the
        # bats shape — otherwise check-useless-excludes flags an exclude matching no files.
        exclude: '\.bats$'
{%- endif %}

  # ----------------------------- ⚙️ GitHub Actions ---------------------------------- #
  # actionlint lints the workflows (and shellchecks their `run:` blocks); zizmor security-
  # audits them. Both are pip-backed hooks that self-bootstrap a pinned env — no system
  # binary, so they run identically locally and in CI.
  - repo: https://github.com/Mateusz-Grzelinski/actionlint-py
    rev: v1.7.12.24
    hooks:
      - id: actionlint
        name: "⚙️ ci · Lint workflows with actionlint"
        # shellcheck-py puts a shellcheck on PATH so actionlint can lint `run:` blocks
        # without depending on a system install.
        additional_dependencies: ["shellcheck-py"]

  - repo: https://github.com/woodruffw/zizmor-pre-commit
    rev: v1.26.1
    hooks:
      - id: zizmor
        name: "🔒 ci · Audit workflows for security issues (zizmor)"
        # --offline keeps the gate deterministic and token-free: the AST audits (template
        # injection, excessive permissions, artipacked, …) run offline, while the network
        # audits (known-vulnerable-actions, ref-confusion) need a GH token and are skipped
        # here — run zizmor online in CI for those. Overriding args drops the upstream
        # default, so re-add --no-progress.
        args: ["--no-progress", "--offline"]

  # ------------------------------- 🔒 Security -------------------------------------- #
  - repo: https://github.com/gitleaks/gitleaks
    rev: v8.30.1
    hooks:
      - id: gitleaks
        name: "🔒 security · Detect secrets with gitleaks"
{% if has_python %}
  # ----------------------- 🔒 Dependency CVEs (supply chain) ------------------------ #
  # ruff `ALL` lints the *code*, not the dependency tree. `uv audit` checks the resolved
  # deps against PyPA advisories; osv-scanner cross-checks uv.lock against the OSV database
  # (and also handles non-Python lockfiles). Both are system tools — uv ships `audit`, and
  # osv-scanner is a release binary (Brewfile/CI install), like hawkeye/taplo — so CI and
  # local match.
  - repo: local
    hooks:
      - id: uv-audit
        name: "🔒 deps · Audit dependencies for CVEs (uv audit)"
        entry: uv audit --preview-features audit-command
        language: system
        files: '^(pyproject\.toml|uv\.lock)$'
        pass_filenames: false
      - id: osv-scanner
        name: "🔒 deps · Scan uv.lock for CVEs (osv-scanner)"
        entry: osv-scanner scan source --lockfile uv.lock
        language: system
        files: '^uv\.lock$'
        pass_filenames: false
{% endif %}
  # --------------------------- ⚖️ Licensing & Compliance ---------------------------- #
  # hawkeye maintains the SPDX headers (config: licenserc.toml); reuse verifies overall
  # REUSE compliance. hawkeye is system (the Brewfile/release binary) so CI/local match.
  - repo: local
    hooks:
      - id: hawkeye-format
        name: "⚖️ license · Add/format SPDX headers with hawkeye"
        entry: hawkeye format
        language: system
        pass_filenames: false
        require_serial: true

  - repo: https://github.com/fsfe/reuse-tool
    rev: v6.2.0
    hooks:
      - id: reuse
        name: "⚖️ license · Check REUSE compliance"

  # ------------------------------- ✨ Spelling -------------------------------------- #
  - repo: https://github.com/crate-ci/typos
    rev: v1.47.2
    hooks:
      - id: typos
        name: "✨ language · Check spelling with typos"
        # CHECK-ONLY: drop the hook default --write-changes; keep --force-exclude.
        args: ["--force-exclude"]
        pass_filenames: false
{% if include_docker %}
  # -------------------------------- 🐳 Docker --------------------------------------- #
  # hadolint is the Dockerfile analog of shellcheck. hadolint-py is pip-backed so it
  # self-bootstraps (no Docker/system install needed).
  - repo: https://github.com/AleksaC/hadolint-py
    rev: v2.14.0
    hooks:
      - id: hadolint
        name: "🐳 docker · Lint Dockerfile with hadolint"
{% endif %}{% if include_terraform %}
  # ------------------------------- 🏗️ Terraform ------------------------------------- #
  # `terraform fmt`/`validate` check syntax, not security — these catch misconfig (e.g. a
  # public bucket). checkov is pip-backed (self-bootstraps); trivy is a system release
  # binary (Brewfile/CI install), like hawkeye/taplo.
  - repo: https://github.com/bridgecrewio/checkov
    rev: 3.3.1
    hooks:
      - id: checkov
        name: "🏗️ terraform · Scan IaC for misconfig (checkov)"
        # Terraform only — zizmor audits workflows, hadolint the Dockerfile.
        args: ["--framework", "terraform", "--quiet", "--compact"]

  - repo: local
    hooks:
      - id: trivy
        name: "🏗️ terraform · Scan IaC for misconfig (trivy)"
        # --exit-code 1 makes findings fail the gate (trivy exits 0 by default).
        entry: trivy config --exit-code 1 terraform
        language: system
        pass_filenames: false
        files: '\.tf$'
{% endif %}{% if include_sql %}
  # ---------------------------------- 🗄️ SQL ---------------------------------------- #
  # sqlfluff lints AND fixes across dialects (config: .sqlfluff). pip-backed → self-
  # bootstraps. fix first (autofix), then lint catches what can't be auto-fixed — the
  # ruff check+format pattern, for SQL.
  - repo: https://github.com/sqlfluff/sqlfluff
    rev: 4.2.2
    hooks:
      - id: sqlfluff-fix
        name: "🗄️ sql · Fix SQL with sqlfluff"
{%- if sql_use_dbt %}
        # The dbt templater is a separate package, and the hook runs in an isolated venv, so
        # it must be installed here. You still need a reachable dbt project to lint models.
        additional_dependencies: ["sqlfluff-templater-dbt"]
{%- endif %}
      - id: sqlfluff-lint
        name: "🗄️ sql · Lint SQL with sqlfluff"
{%- if sql_use_dbt %}
        additional_dependencies: ["sqlfluff-templater-dbt"]
{%- endif %}
{% endif %}{% if has_python %}
  # -------------------------------- 🐍 Python --------------------------------------- #
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.15.17
    hooks:
      - id: ruff-check
        name: "🐍 python · Lint with Ruff"
        args: [--fix, --exit-non-zero-on-fix]
      - id: ruff-format
        name: "🐍 python · Format with Ruff"

  - repo: https://github.com/abravalheri/validate-pyproject
    rev: v0.25
    hooks:
      - id: validate-pyproject
        name: "🐍 python · Validate pyproject.toml"
        additional_dependencies: ["validate-pyproject-schema-store[all]"]
{% endif %}
  # -------------------------------- 📝 Markdown ------------------------------------- #
  - repo: https://github.com/rvben/rumdl-pre-commit
    rev: v0.2.17
    hooks:
      - id: rumdl
        name: "📝 markdown · Lint/format with rumdl"
        args: [--fix]
{% if has_python %}
  # ----------------------------- ⚙️ Environment ------------------------------------- #
  - repo: https://github.com/astral-sh/uv-pre-commit
    rev: 0.11.21
    hooks:
      - id: uv-lock
        name: "⚙️ uv · Keep uv.lock in sync with pyproject.toml"
{% endif %}
  # ------------------------------ ✨ Commit Messages -------------------------------- #
  # Plain Conventional Commits (no gitmoji): release-please derives version bumps from
  # commit types and cannot parse a leading emoji, so commits must start with the bare type.
  - repo: https://github.com/commitizen-tools/commitizen
    rev: v4.16.3
    hooks:
      - id: commitizen
        name: "✨ commit-msg · Enforce Conventional Commits"
        stages: [commit-msg]

  # --------------------- 🛠️ Local Tools (prek can't bootstrap) ---------------------- #
  - repo: local
    hooks:
      - id: prek-validate-config
        name: "🔧 pre-commit · Validate .pre-commit-config.yaml"
        entry: prek validate-config
        language: system
        files: '^\.pre-commit-config\.yaml$'
{% if has_python %}
      - id: ty
        name: "🐍 python · Type-check with ty"
        entry: uv run ty check .
        language: system
        types: [python]
        pass_filenames: false
{% endif %}
      - id: taplo
        name: "📝 toml · Format with taplo"
        entry: taplo format
        language: system
        types: [toml]
        pass_filenames: false
