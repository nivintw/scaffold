# SPDX-FileCopyrightText: © {{ year }} {{ author_name }}
# SPDX-License-Identifier: {{ license }}

{% if not python_source -%}
# Not an installable package — this pyproject hosts the Python tooling config (ruff, ty
{%- if 'pytest' in test_frameworks %}, pytest{% endif %}) and gives uv a managed dev env.
# `[tool.uv] package = false` keeps uv from trying to build the repo. Run: uv run <tool>.
{% endif -%}
[project]
name = "{{ project_slug }}"
version = "0.0.0"
requires-python = ">={{ python_version }}"
description = "{{ project_description }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
license = "{{ license }}"
license-files = ["LICENSE", "LICENSES/*"]
{%- if is_package and python_source %}
readme = "README.md"
classifiers = [
  "Programming Language :: Python :: 3",
  "Operating System :: OS Independent",
]
{%- else %}
classifiers = ["Programming Language :: Python :: 3"]
{%- endif %}
dependencies = []

[dependency-groups]
# Kept on one line so taplo doesn't reformat it (it collapses short arrays); the set is
# small now that release-please — not commitizen — owns releases.
dev = ["ruff>=0.8", "ty>=0.0.1"{% if 'pytest' in test_frameworks %}, "pytest>=8"{% if python_source %}, "pytest-cov>=5"{% endif %}{% endif %}]

[tool.uv]
package = {{ 'true' if python_source else 'false' }}

{% if python_source -%}
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ python_package }}"]

{% endif -%}
{%- if 'pytest' in test_frameworks -%}
[tool.pytest.ini_options]
testpaths = ["tests"]
{%- if python_source %}
# Coverage gate — measure the package, fail under 80%. Tune per project.
addopts = "--cov={{ python_package }} --cov-report=term-missing --cov-fail-under=80"
{%- endif %}

{% endif -%}
[tool.ruff]
target-version = "py{{ python_version.split('.')[0] }}{{ python_version.split('.')[1] }}"
line-length = 100

[tool.ruff.format]
docstring-code-format = true

[tool.ruff.lint]
extend-select = ["ALL"]
ignore = ["D203", "D212", "D401", "COM812", "ISC001"]

[tool.ruff.lint.pydocstyle]
convention = "google"
{% if 'pytest' in test_frameworks %}
[tool.ruff.lint.per-file-ignores]
"tests/**" = ["S101", "INP001"] # tests use assert; not an importable package
{% endif -%}
