[markdown_custom]
firstLine = "<!--"
# Trailing newline is intentional (rumdl wants a blank line after the header).
endLine = "-->\n"
firstLineDetectionPattern = "^<!--"
lastLineDetectionPattern = "-->"
multipleLines = true
