//
// Renovate config for the TEMPLATE repo itself (dogfood). Renovate's native managers can't
// see the pins INSIDE template/**/*.jinja (they aren't .yaml/.pre-commit-config), so those
// are picked up by the customManagers below. The repo's OWN .github/workflows/*.yml is
// handled natively by the github-actions manager. Generated projects get their own config
// from template/.github/renovate.json.
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests",
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group Ruff bumps so a new rule under extend-select=ALL lands as one reviewable PR.",
      "matchPackageNames": ["astral-sh/ruff-pre-commit"],
      "groupName": "ruff",
    },
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "pre-commit hook revs pinned inside the generated .pre-commit-config.yaml.jinja",
      "managerFilePatterns": ["/^template/\\.pre-commit-config\\.yaml\\.jinja$/"],
      "matchStrings": [
        "repo:\\s+https://github\\.com/(?<depName>[^\\s/]+/[^\\s/]+)\\s+rev:\\s+(?<currentValue>\\S+)",
      ],
      "datasourceTemplate": "github-tags",
    },
    {
      "customType": "regex",
      "description": "SHA-pinned actions inside the generated workflow .jinja files",
      "managerFilePatterns": ["/^template/\\.github/workflows/.+\\.jinja$/"],
      "matchStrings": [
        "uses:\\s+(?<depName>[\\w.-]+/[\\w.-]+)@(?<currentDigest>[a-f0-9]{40})\\s+#\\s+(?<currentValue>v\\S+)",
      ],
      "datasourceTemplate": "github-tags",
    },
    {
      "customType": "regex",
      "description": "Pinned hawkeye/taplo release binaries fetched in CI (own workflow + the generated one)",
      "managerFilePatterns": [
        "/^\\.github/workflows/.+\\.ya?ml$/",
        "/^template/\\.github/workflows/.+\\.jinja$/",
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+[\\s\\S]*?/releases/download/(?<currentValue>[^/]+)/",
      ],
    },
  ],
}
