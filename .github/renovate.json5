//
// Renovate config for the TEMPLATE repo itself (dogfood). Renovate's native managers can't
// see the pins INSIDE template/**/*.jinja (they aren't .yaml/.pre-commit-config), so those
// are picked up by the customManagers below. The repo's OWN .github/workflows/*.yml is
// handled natively by the github-actions manager. Generated projects get their own config
// from template/.github/renovate.json.
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests",
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group Ruff bumps so a new rule under extend-select=ALL lands as one reviewable PR.",
      "matchPackageNames": ["astral-sh/ruff-pre-commit"],
      "groupName": "ruff",
    },
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "pre-commit hook revs pinned inside the generated .pre-commit-config.yaml.jinja",
      "managerFilePatterns": ["/^template/\\.pre-commit-config\\.yaml\\.jinja$/"],
      "matchStrings": [
        "repo:\\s+https://github\\.com/(?<depName>[^\\s/]+/[^\\s/]+)\\s+rev:\\s+(?<currentValue>\\S+)",
      ],
      "datasourceTemplate": "github-tags",
    },
    {
      "customType": "regex",
      "description": "SHA-pinned actions inside the generated workflow .jinja files",
      "managerFilePatterns": ["/^template/\\.github/workflows/.+\\.jinja$/"],
      "matchStrings": [
        "uses:\\s+(?<depName>[\\w.-]+/[\\w.-]+)@(?<currentDigest>[a-f0-9]{40})\\s+#\\s+(?<currentValue>v\\S+)",
      ],
      "datasourceTemplate": "github-tags",
    },
    {
      "customType": "regex",
      "description": "Release binaries pinned by a `# renovate:`-annotated *_VERSION env var (trivy, osv-scanner, hawkeye, taplo, kubeconform) — own + generated workflows. Renovate bumps the version; the adjacent *_SHA256 is refreshed by scripts/refresh-binary-checksums.sh, run as a postUpgradeTask (below) so the fix lands in Renovate's own commit, since github-releases has no asset-digest datasource.",
      "managerFilePatterns": [
        "/^\\.github/workflows/.+\\.ya?ml$/",
        "/^template/\\.github/workflows/.+\\.jinja$/",
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+\\w+: \"(?<currentValue>[^\"]+)\"",
      ],
    },
    {
      "customType": "regex",
      "description": "uv image pinned in the generated Dockerfile.jinja (Renovate's docker manager can't parse .jinja)",
      "managerFilePatterns": ["/Dockerfile.*\\.jinja$/"],
      "matchStrings": [
        "COPY --from=(?<depName>ghcr\\.io/astral-sh/uv):(?<currentValue>\\S+) ",
      ],
      "datasourceTemplate": "docker",
    },
  ],
  // Refresh the *_SHA256 next to each bumped *_VERSION in Renovate's own commit. The central
  // self-hosted runner executes this (its allowedCommands authorizes the script). fileFilters
  // also covers template/.github/workflows/** because this repo's script refreshes the pins
  // inside the generated workflow .jinja files too.
  //
  // The runner must also export BASE_REF=origin/<base-branch> so the script's supply-chain
  // tamper gate stays active (it refuses to re-pin a SHA whose *_VERSION did NOT change vs
  // BASE_REF — a swapped asset on a fixed tag). Run bare (no BASE_REF), the gate is off and
  // every pin is recomputed. Wiring this into the runner is a repo-management follow-up.
  "postUpgradeTasks": {
    "commands": ["scripts/refresh-binary-checksums.sh"],
    "fileFilters": [".github/workflows/**", "template/.github/workflows/**"],
    "executionMode": "branch",
  },
}
